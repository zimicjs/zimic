{
  "extends": "@zimic/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "types": ["node", "@zimic/utils/types/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"],
      "@@/package.json": ["./package.json"]
    }
  },
  "include": ["**/*.ts", "**/*.mts"],
  "exclude": ["node_modules", "dist", "*.d.ts"]
}
