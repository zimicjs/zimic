{
  "name": "zimic-example-with-next-js-pages",
  "version": "0.0.0",
  "private": false,
  "scripts": {
    "setup": "concurrently --names playwright,zimic 'playwright install chromium' 'zimic-interceptor browser init ./public || true'",
    "dev": "dotenv -c development -- next dev",
    "test": "dotenv -c test -- dotenv -c development -- playwright test",
    "test:turbo": "dotenv -v CI=true -- pnpm run test",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@zimic/fetch": "latest",
    "@zimic/http": "latest",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@zimic/interceptor": "latest",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "@typescript/native": "npm:typescript@^7.0.2"
  }
}
