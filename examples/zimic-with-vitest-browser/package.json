{
  "name": "zimic-example-with-vitest-browser",
  "version": "0.0.0",
  "private": false,
  "scripts": {
    "setup": "concurrently --names playwright,zimic 'playwright install chromium' 'zimic-interceptor browser init ./public || true'",
    "test": "vitest",
    "test:turbo": "dotenv -v CI=true -- pnpm run test --reporter verbose",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@zimic/fetch": "latest",
    "@zimic/http": "latest"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@zimic/interceptor": "latest",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "playwright": "^1.61.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "@typescript/native": "npm:typescript@^7.0.2",
    "vitest": "^4.1.10"
  }
}
