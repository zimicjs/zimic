{
  "name": "zimic-example-with-playwright",
  "version": "0.0.0",
  "private": false,
  "scripts": {
    "setup": "playwright install chromium",
    "dev": "dotenv -c development -- next dev",
    "mock": "zimic-interceptor server start --hostname 127.0.0.1 --port 4002 --ephemeral",
    "test": "dotenv -c test -- dotenv -c development -- pnpm mock -- playwright test",
    "test:turbo": "dotenv -v CI=true -- pnpm run test",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@zimic/fetch": "latest",
    "@zimic/http": "latest",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@zimic/interceptor": "latest",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "@typescript/native": "npm:typescript@^7.0.2"
  }
}
