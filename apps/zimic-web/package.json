{
  "name": "zimic-web",
  "version": "0.3.60",
  "private": true,
  "scripts": {
    "dev": "docusaurus start --host :: --no-open",
    "build": "docusaurus build",
    "start": "docusaurus serve --no-open",
    "lint": "eslint --cache --no-error-on-unmatched-pattern --no-warn-ignored --fix",
    "lint:turbo": "pnpm lint . --max-warnings 0",
    "style": "prettier --log-level warn --ignore-unknown --no-error-on-unmatched-pattern --cache",
    "style:check": "pnpm style --check",
    "style:format": "pnpm style --write",
    "types:check": "tsc --noEmit",
    "generate:sponsors": "dotenv -c development -- sponsorkit"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/plugin-content-docs": "^3.10.0",
    "@docusaurus/plugin-content-pages": "^3.10.0",
    "@docusaurus/plugin-sitemap": "^3.10.0",
    "@docusaurus/plugin-svgr": "^3.10.0",
    "@docusaurus/theme-classic": "^3.10.0",
    "@docusaurus/theme-search-algolia": "^3.10.0",
    "@mdx-js/react": "^3.1.1",
    "@tanstack/react-query": "^5.99.2",
    "@zimic/fetch": "workspace:*",
    "@zimic/http": "workspace:*",
    "dompurify": "^3.4.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@zimic/eslint-config-react": "workspace:*",
    "@zimic/lint-staged-config": "workspace:*",
    "@zimic/tsconfig": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "esbuild-loader": "^4.4.3",
    "eslint": "^9.39.4",
    "postcss": "^8.5.10",
    "sponsorkit": "^17.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.3"
  }
}
